<%- include("partials/header.ejs") %>

<div class="container mt-4">
    <h2 class="game-title"><%= username %>'s Profile</h2>

    <% if (reviews.length === 0) { %>
        <p>You haven't reviewed any games yet. <a href="/">Search for a game</a> to get started.</p>
    <% } else { %>
        <h4 class="mt-3">Your Reviews</h4>
        <ul class="list-group mt-2">
            <% reviews.forEach(r => { %>
                <li class="list-group-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong>
                            <% if (r.steam_appid) { %>
                                <a href="/review/<%= r.steam_appid %>"><%= r.title %></a>
                            <% } else { %>
                                <%= r.title %>
                            <% } %>
                        </strong>
                        <span class="badge bg-primary"><%= r.rating %>/10</span>
                    </div>
                    <p class="mb-1 mt-1"><%= r.review_text %></p>
                    <small class="text-muted"><%= new Date(r.created_at).toLocaleDateString() %></small>
                </li>
            <% }) %>
        </ul>
    <% } %>
</div>

<%- include("partials/footer.ejs") %>
