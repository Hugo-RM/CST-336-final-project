<%- include("partials/header.ejs") %>

<div class="container mt-4">
    <h2 class="game-title"><%= username %>'s Profile</h2>

    <% if (reviews.length === 0) { %>
        <p>You haven't reviewed any games yet. <a href="/">Search for a game</a> to get started.</p>
    <% } else { %>
        <h4 class="mt-3 reviews-heading">Your Reviews</h4>
        <div class="reviews-container mt-2">
            <% reviews.forEach(r => { %>
                <div class="review-card">
                    <div class="review-header">
                        <strong class="review-title"><%= r.title %></strong>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-primary"><%= r.rating %>/10</span>
                            <a href="/review/game/<%= r.game_id %>" class="btn btn-sm btn-outline-secondary">Edit</a>
                        </div>
                    </div>
                    <p class="review-text"><%= r.review_text %></p>
                    <small class="review-date"><%= new Date(r.created_at).toLocaleDateString() %></small>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include("partials/footer.ejs") %>
