<%- include("partials/header.ejs") %>

<style>
    .review-page {
        background: linear-gradient(135deg, #000FB5, #0033FF, #1E2AD8);
        min-height: 100vh;
        animation: homePageGlow 3s infinite ease-in-out;
        padding: 32px 20px;
    }

    .review-card {
        max-width: 680px;
        margin: 0 auto;
        background: #f5f8ff;
        border: 2px solid #d8e4ff;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0, 51, 255, 0.15);
        overflow: hidden;
    }

    .review-card-header {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 20px 24px;
        background: #eef2ff;
        border-bottom: 2px solid #d8e4ff;
    }

    .review-game-image {
        width: 120px;
        border-radius: 8px;
        flex-shrink: 0;
    }

    .review-game-title {
        font-family: 'Pixelify Sans', sans-serif;
        font-size: 26px;
        color: #10225f;
        margin: 0;
    }

    .review-card-body {
        padding: 24px;
    }

    .review-label {
        font-family: 'Baloo 2', sans-serif;
        font-weight: 700;
        color: #10225f;
        margin-bottom: 6px;
        display: block;
    }

    .review-input, .review-textarea {
        font-family: 'Baloo 2', sans-serif;
        font-size: 15px;
        width: 100%;
        padding: 10px 14px;
        border: 2px solid #d8e4ff;
        border-radius: 10px;
        background: #ffffff;
        color: #16213d;
        box-sizing: border-box;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
        outline: none;
    }

    .review-input:focus, .review-textarea:focus {
        border-color: #00c2c2;
        box-shadow: 0 0 0 3px rgba(0, 194, 194, 0.15);
    }

    .review-input {
        max-width: 120px;
    }

    .review-textarea {
        resize: vertical;
        min-height: 140px;
    }

    .review-submit-btn {
        font-family: 'Baloo 2', sans-serif;
        font-weight: 900;
        font-size: 15px;
        letter-spacing: 1px;
        text-transform: uppercase;
        background: linear-gradient(145deg, #00c2c2, #64e6e6);
        color: #000000;
        border: 2px solid #000000;
        border-radius: 8px;
        padding: 10px 28px;
        cursor: pointer;
        box-shadow: 0 4px 0 #000000;
        transition: all 0.1s ease;
        position: relative;
        top: 0;
    }

    .review-submit-btn:hover {
        transform: translateY(2px);
        box-shadow: 0 2px 0 #000000;
    }

    .review-submit-btn:active {
        transform: translateY(4px);
        box-shadow: none;
    }

    .review-cancel-btn {
        font-family: 'Baloo 2', sans-serif;
        font-weight: 700;
        color: #555;
        text-decoration: none;
        padding: 10px 20px;
        border: 2px solid #ccc;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

    .review-cancel-btn:hover {
        border-color: #888;
        color: #222;
    }
</style>

<div class="review-page">
    <div class="review-card">
        <div class="review-card-header">
            <% if (steamAppid) { %>
                <img src="https://cdn.akamai.steamstatic.com/steam/apps/<%= steamAppid %>/header.jpg"
                     alt="<%= title %>"
                     class="review-game-image"
                     onerror="this.style.display='none'">
            <% } %>
            <h2 class="review-game-title"><%= title %></h2>
        </div>

        <div class="review-card-body">
            <% if (error) { %>
                <div class="alert alert-danger mb-3"><%= error %></div>
            <% } %>

            <% if (existing) { %>
                <div class="alert alert-info mb-3">You've already reviewed this game — submitting will update your review.</div>
            <% } %>

            <form action="<%= gameId ? '/review/game/' + gameId : '/review/steam/' + steamAppid %>" method="POST">
                <div class="mb-4">
                    <label for="rating" class="review-label">Rating (1–10)</label>
                    <input type="number" id="rating" name="rating" class="review-input"
                           min="1" max="10" required
                           value="<%= existing ? existing.rating : '' %>">
                </div>

                <div class="mb-4">
                    <label for="review_text" class="review-label">Your Review</label>
                    <textarea id="review_text" name="review_text" class="review-textarea" required><%= existing ? existing.review_text : '' %></textarea>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <button type="submit" class="review-submit-btn">
                        <%= existing ? 'Update Review' : 'Submit Review' %>
                    </button>
                    <a href="/catalog" class="review-cancel-btn">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include("partials/footer.ejs") %>
