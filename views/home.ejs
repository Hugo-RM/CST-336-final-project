<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/header.ejs") %>

</head>
<body class="home-page">

    <h1 class="search-title">Search for a Game</h1>

    <form action="/searchGame" method="GET">
        <input type="text" name="name" class="search-input" placeholder="Enter game name">
        <button type="submit" class="search-btn">Search</button>
    </form>

    <hr>

    <% 
    let rating = null;

    if (spyData && spyData.positive && spyData.negative) {
        let total = spyData.positive + spyData.negative;
        rating = Math.round((spyData.positive / total) * 100);
    }

    let genre = null;
    if (game && game.genres && game.genres.length > 0) {
        genre = game.genres[0].description;
    }
    %>

    <% if (game) { %>
        <div class="game-result-container">
            <div class="game-result-left">
                <h2 class="game-title"><%= game.name %></h2>

                <img class="game-image" src="<%= game.header_image %>" alt="<%= game.name %>">
            </div>

            <div class="game-result-right">
                <p class="game-detail"><%= game.short_description %></p>

                <% if (genre) { %>
                    <p class="game-detail"><strong>Genre:</strong> <%= genre %></p>
                <% } else { %>
                    <p class="game-detail"><strong>Genre:</strong> N/A</p>
                <% } %>

                <% if (game.price_overview) { %>
                    <p class="game-detail"><strong>Price:</strong> $<%= (game.price_overview.final / 100).toFixed(2) %></p>
                <% } else { %>
                    <p class="game-detail"><strong>Price:</strong> Free / N/A</p>
                <% } %>

                <% if (rating !== null) { %>
                    <p class="game-detail"><strong>Rating:</strong> <%= rating %>% Positive</p>
                <% } else { %>
                    <p class="game-detail"><strong>Rating:</strong> No rating data</p>
                <% } %>

                <% if (game.metacritic && game.metacritic.score) { %>
                    <p class="game-detail"><strong>Metacritic:</strong> <%= game.metacritic.score %></p>
                <% } else { %>
                    <p class="game-detail"><strong>Metacritic:</strong> N/A</p>
                <% } %>

                <% if (game.platforms) { %>
                    <div class="game-detail">
                        <strong>Platforms:</strong>

                        <% if (game.platforms.windows) { %>
                            <span>Windows </span>
                        <% } %>

                        <% if (game.platforms.mac) { %>
                            <span>Mac </span>
                        <% } %>

                        <% if (game.platforms.linux) { %>
                            <span>Linux </span>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    <% } %>

    <%- include("partials/footer.ejs") %>

</body>
</html>