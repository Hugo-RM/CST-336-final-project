<%- include("partials/header.ejs") %>

<style>
    .error-page {
        background: linear-gradient(135deg, #000FB5, #0033FF, #1E2AD8);
        min-height: 80vh;
        animation: homePageGlow 3s infinite ease-in-out;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        text-align: center;
    }

    .error-code {
        font-family: 'Pixelify Sans', sans-serif;
        font-size: 120px;
        color: #ffffff;
        line-height: 1;
        margin: 0;
        text-shadow: 0 0 30px rgba(0, 194, 194, 0.8);
    }

    .error-message {
        font-family: 'Baloo 2', sans-serif;
        font-size: 22px;
        color: rgba(255,255,255,0.85);
        margin: 16px 0 32px;
    }
</style>

<div class="error-page">
    <h1 class="error-code"><%= code %></h1>
    <p class="error-message"><%= message %></p>
    <a href="/" class="nav-buttons">Go Home</a>
</div>

<%- include("partials/footer.ejs") %>
